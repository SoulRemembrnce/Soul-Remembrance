rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Practitioners (legacy path)
    match /practitioners/{userId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Practitioner profiles (primary path used by the app)
    match /practitionerProfiles/{userId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Services (offered by practitioners — practitioners write, anyone can read)
    match /services/{serviceId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Waitlist entries (retreat/group sessions)
    match /waitlist/{entryId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // Verification applications (submitted by practitioners)
    match /verificationApplications/{appId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
    }

    // Admins sentinel (written by admin panel on sign-in)
    match /admins/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Push tokens (device push notification tokens)
    match /pushTokens/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Bookings
    match /bookings/{bookingId} {
      allow read: if request.auth != null &&
        (resource.data.clientId == request.auth.uid ||
         resource.data.practitionerId == request.auth.uid);
      allow create: if request.auth != null &&
        request.resource.data.clientId == request.auth.uid;
      allow update: if request.auth != null &&
        (resource.data.clientId == request.auth.uid ||
         resource.data.practitionerId == request.auth.uid);
    }

    // Messages
    match /messages/{messageId} {
      allow read, write: if request.auth != null &&
        (resource == null ||
         resource.data.senderId == request.auth.uid ||
         resource.data.receiverId == request.auth.uid);
    }

    // Conversations
    match /conversations/{conversationId} {
      allow read, write: if request.auth != null &&
        (resource == null ||
         request.auth.uid in resource.data.participantIds);
    }

    // Group chats
    match /groupChats/{groupId} {
      allow read: if request.auth != null &&
        request.auth.uid in resource.data.memberUids;
      allow write: if request.auth != null;
      match /messages/{msgId} {
        allow read, write: if request.auth != null;
      }
    }

    // Reviews
    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if request.auth != null &&
        request.resource.data.clientId == request.auth.uid;
      allow update, delete: if request.auth != null &&
        resource.data.clientId == request.auth.uid;
    }

    // User profiles
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Dream Journal — each user owns their own entries
    match /dreamJournal/{userId}/entries/{entryId} {
      allow read, write: if request.auth != null &&
        request.auth.uid == userId &&
        !request.auth.token.firebase.sign_in_provider.matches("anonymous");
    }

    // Waiver templates (practitioners create, clients read before booking)
    match /waiverTemplates/{templateId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Waiver signatures (clients sign, both client and practitioner can read)
    match /waiverSignatures/{sigId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null &&
        request.resource.data.userId == request.auth.uid;
      allow update, delete: if request.auth != null &&
        resource.data.userId == request.auth.uid;
    }

  }
}
