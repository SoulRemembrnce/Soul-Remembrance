rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Avatar images — readable by anyone, writable only by the owning user
    match /avatars/{role}/{userId}.jpg {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Verification documents — only the owning practitioner can write;
    // admin can read (via Firebase Console / Admin SDK which bypasses rules).
    match /verificationDocs/{userId}/{document=**} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
