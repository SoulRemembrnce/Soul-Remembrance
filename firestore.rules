rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ────────────────────────────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // Checks a lightweight /admins/{uid} sentinel written by the admin panel
    // on first sign-in. Only verified-email, signed-in users can write to it,
    // and the admin panel's VITE_ADMIN_EMAILS gate ensures only approved
    // addresses ever reach that call.
    function isAdmin() {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // ── admins collection ──────────────────────────────────────────────────
    match /admins/{uid} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && (
        (request.auth.uid == uid && request.auth.token.email_verified == true) ||
        isAdmin()
      );
    }

    // ── Public read-only collections ───────────────────────────────────────
    match /practitioners/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /events/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ── Practitioner profiles ──────────────────────────────────────────────
    // Document ID = Firebase Auth UID of the practitioner.
    // Public read so Explore works without sign-in.
    // Only the owner can update their own profile — this covers every field:
    // onboarding, photoURL, subscriptionActive, stripeAccountId, featuredUntil, etc.
    match /practitionerProfiles/{userId} {
      allow read: if true;
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
    }

    // ── Reviews ────────────────────────────────────────────────────────────
    match /reviews/{id} {
      allow read: if true;
      allow create: if isSignedIn()
        && request.resource.data.authorName is string
        && request.resource.data.rating is number
        && request.resource.data.rating >= 1
        && request.resource.data.rating <= 5;
      allow update, delete: if isAdmin();
    }

    // ── Community posts ────────────────────────────────────────────────────
    match /posts/{id} {
      allow read: if true;
      allow create: if isSignedIn()
        && request.resource.data.authorId == request.auth.uid
        && request.resource.data.text is string
        && request.resource.data.text.size() > 0
        && request.resource.data.text.size() <= 2000;
      allow update: if isSignedIn();
      allow delete: if isSignedIn()
        && (resource.data.authorId == request.auth.uid || isAdmin());
    }

    // ── Services (practitioner offerings) ─────────────────────────────────
    // Public read so clients can browse session types before booking.
    match /services/{id} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // ── Availability slots ─────────────────────────────────────────────────
    match /availability/{id} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (
        (resource.data.booked == false
          && request.resource.data.booked == true
          && request.resource.data.bookedBy == request.auth.uid) ||
        resource.data.practitionerId == request.auth.uid ||
        isAdmin()
      );
      allow delete: if isSignedIn() && (
        resource.data.practitionerId == request.auth.uid || isAdmin()
      );
    }

    // ── Bookings ───────────────────────────────────────────────────────────
    match /bookings/{id} {
      allow read: if isSignedIn() && (
        resource.data.userId == request.auth.uid ||
        resource.data.practitionerId == request.auth.uid ||
        isAdmin()
      );
      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid;
      allow update: if isSignedIn() && (
        resource.data.userId == request.auth.uid ||
        resource.data.practitionerId == request.auth.uid ||
        isAdmin()
      );
      allow delete: if isAdmin();
    }

    // ── Favourites ─────────────────────────────────────────────────────────
    match /favorites/{id} {
      allow read: if isSignedIn() && isOwner(resource.data.userId);
      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid;
      allow delete: if isSignedIn() && isOwner(resource.data.userId);
      allow update: if false;
    }

    // ── Messaging ──────────────────────────────────────────────────────────
    // Conversations store `userId` = the client's Firebase Auth UID.
    // (No `participants` array — the practitionerId is a numeric platform ID,
    // not a Firebase UID, so we key access off the client's userId field.)
    match /conversations/{convId} {
      allow read: if isSignedIn() && (
        resource.data.userId == request.auth.uid || isAdmin()
      );
      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid;
      allow update: if isSignedIn() && (
        resource.data.userId == request.auth.uid || isAdmin()
      );
      allow delete: if isAdmin();

      match /messages/{msgId} {
        allow read: if isSignedIn() && (
          get(/databases/$(database)/documents/conversations/$(convId))
            .data.userId == request.auth.uid || isAdmin()
        );
        allow create: if isSignedIn() && (
          get(/databases/$(database)/documents/conversations/$(convId))
            .data.userId == request.auth.uid
        );
        allow update, delete: if isAdmin();
      }
    }

    // ── Push tokens ────────────────────────────────────────────────────────
    // Only the token owner can read or write their own push token.
    match /pushTokens/{userId} {
      allow read, write: if isOwner(userId);
    }

    // ── Following ──────────────────────────────────────────────────────────
    match /following/{id} {
      allow read: if isSignedIn() && isOwner(resource.data.userId);
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow delete: if isSignedIn() && isOwner(resource.data.userId);
      allow update: if false;
    }

    // ── User profiles (retreat counts, etc.) ───────────────────────────────
    match /users/{userId} {
      allow read, write: if isOwner(userId) || isAdmin();

      match /journal/{entryId} {
        allow read, write: if isOwner(userId);
      }

      match /gratitude/{entryId} {
        allow read, write: if isOwner(userId);
      }

      match /visionBoard/{itemId} {
        allow read, write: if isOwner(userId);
      }

      match /moodCheckins/{entryId} {
        allow read, write: if isOwner(userId);
      }

      match /affirmationFavourites/{entryId} {
        allow read, write: if isOwner(userId);
      }

      match /customAffirmations/{entryId} {
        allow read, write: if isOwner(userId);
      }
    }

    // ── Waiver templates (practitioner-authored) ───────────────────────────
    // Public read so the booking screen can fetch them without auth.
    // Only the owning practitioner can create/delete their own waivers.
    match /waiverTemplates/{id} {
      allow read: if true;
      allow create: if isSignedIn()
        && request.resource.data.practitionerUid == request.auth.uid;
      allow delete: if isSignedIn()
        && resource.data.practitionerUid == request.auth.uid;
      allow update: if isSignedIn()
        && resource.data.practitionerUid == request.auth.uid;
    }

    // ── Waiver signatures (client-signed records) ──────────────────────────
    // Clients can create and read their own signed waivers.
    match /waiverSignatures/{id} {
      allow read: if isSignedIn() && (
        resource.data.userId == request.auth.uid || isAdmin()
      );
      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    // ── Waitlist ───────────────────────────────────────────────────────────
    // Clients can create/delete their own entry; practitioners can read entries
    // for their services (matched via practitionerUid field).
    match /waitlist/{id} {
      allow read: if isSignedIn() && (
        resource.data.userId == request.auth.uid ||
        resource.data.practitionerUid == request.auth.uid ||
        isAdmin()
      );
      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid;
      allow delete: if isSignedIn()
        && resource.data.userId == request.auth.uid;
      allow update: if isAdmin();
    }

    // ── Group Chats (Retreat Communities) ─────────────────────────────────
    // Only members (by UID in memberUids array) can read/write.
    match /groupChats/{chatId} {
      allow read: if isSignedIn() &&
        request.auth.uid in resource.data.memberUids;
      allow create: if isSignedIn() &&
        request.auth.uid in request.resource.data.memberUids;
      allow update: if isSignedIn() && (
        request.auth.uid in resource.data.memberUids || isAdmin()
      );
      allow delete: if isAdmin();

      match /messages/{msgId} {
        allow read, create: if isSignedIn() &&
          request.auth.uid in
            get(/databases/$(database)/documents/groupChats/$(chatId)).data.memberUids;
        allow update, delete: if isAdmin();
      }
    }

    // ── Verification applications ───────────────────────────────────────────
    // Practitioners create their own; only admin can update (approve/reject).
    match /verificationApplications/{id} {
      allow read: if isSignedIn() && (
        resource.data.practitionerUid == request.auth.uid || isAdmin()
      );
      allow create: if isSignedIn()
        && request.resource.data.practitionerUid == request.auth.uid;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }
  }
}
